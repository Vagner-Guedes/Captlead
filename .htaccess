# ============================================
# 🔒 CAPTLEADS - CONFIGURAÇÃO DE SEGURANÇA
# ============================================

# Forçar HTTPS (IMPORTANTE: ative SSL no HostGator primeiro)
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Prevenir listagem de diretórios
Options -Indexes

# Proteger arquivos sensíveis
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|bak|config|env|json|lock|md|txt)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Proteger configuração do PHP
<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

# ============================================
# HEADERS DE SEGURANÇA
# ============================================
<IfModule mod_headers.c>
    # XSS Protection
    Header set X-XSS-Protection "1; mode=block"
    
    # Clickjacking Protection
    Header set X-Frame-Options "SAMEORIGIN"
    
    # MIME Type Sniffing
    Header set X-Content-Type-Options "nosniff"
    
    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Content Security Policy (CSP) - Ajuste conforme necessário
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://unpkg.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; font-src 'self' https://cdnjs.cloudflare.com; media-src 'self' data:; connect-src 'self';"
    
    # Cache de assets estáticos (1 ano)
    <FilesMatch "\.(css|js|jpg|jpeg|png|gif|ico|svg|webp|mp4|woff2)$">
        Header set Cache-Control "max-age=31536000, public, immutable"
    </FilesMatch>
    
    # Cache curto para HTML/PHP
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "max-age=3600, public, must-revalidate"
    </FilesMatch>
</IfModule>

# ============================================
# PREVENIR SQL INJECTION E ATAQUES COMUNS
# ============================================
RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2})
RewriteRule ^(.*)$ - [F,L]

# Bloquear acesso a arquivos começando com ponto
RedirectMatch 403 /\..*$

# ============================================
# REDIRECIONAMENTOS E URLS AMIGÁVEIS
# ============================================
RewriteCond %{THE_REQUEST} /index\.(php|html) [NC]
RewriteRule ^index\.(php|html)$ / [R=301,L]

# ============================================
# COMPRESSÃO GZIP
# ============================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>